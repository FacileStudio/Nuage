# Domain (required for production)
ORIGIN=https://nuage.facile.studio

# Presigned URL signing secret (recommended for production)
# Generate with: openssl rand -hex 32
PRESIGN_SECRET=

# OIDC (optional — leave empty to use email/password auth)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://nuage.facile.studio/api/auth/oidc/callback
OIDC_SUCCESS_URL=https://nuage.facile.studio
SSO_ONLY=false
